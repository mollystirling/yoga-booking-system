{{> head}}
{{> header}}

<h1>Courses</h1>

<section class="filters">
  <form class="filter-form" method="get" action="/courses">
    <div class="field">
      <label for="level">Level</label>
      <select id="level" name="level">
        <option value="" {{^filters.level}}selected{{/filters.level}}>Any</option>
        <option value="beginner" {{#filters.isBeginner}}selected{{/filters.isBeginner}}>Beginner</option>
        <option value="intermediate" {{#filters.isIntermediate}}selected{{/filters.isIntermediate}}>Intermediate</option>
        <option value="advanced" {{#filters.isAdvanced}}selected{{/filters.isAdvanced}}>Advanced</option>
      </select>
    </div>

    <div class="field">
      <label for="q">Search</label>
      <input id="q" type="search" name="q" value="{{filters.q}}" placeholder="Title or description" />
    </div>

    <div class="filter-actions">
      <button class="btn primary" type="submit">Apply</button>
      <a class="btn" href="/courses">Reset</a>
    </div>
  </form>
</section>

<div class="cards">
  {{#courses}}
  <article class="card">
    <h2><a href="/courses/{{id}}">{{title}}</a></h2>
    <p class="muted">
      Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
    </p>
    <p>{{description}}</p>
    <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
    <p class="muted">Next session: {{nextSession}} • Sessions: {{sessionsCount}}</p>
    <p><a class="btn" href="/courses/{{id}}">View &amp; Book</a></p>
  </article>
  {{/courses}}

  {{^courses}}
    <p>No courses match your filters.</p>
  {{/courses}}
</div>

{{> footer}}
