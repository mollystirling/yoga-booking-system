{{> head}}
{{> header}}

<h1>Upcoming Courses</h1>

<div class="cards">
  {{#courses}}
  <article class="card">
    <h2><a href="/courses/{{id}}">{{title}}</a></h2>
    <p class="muted">
      Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
    </p>
    <p>{{description}}</p>
    <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
    <p class="muted">
      {{#location}}Location: {{location}} • {{/location}}
      {{#price}}Price: £{{price}} • {{/price}}
      Next session: {{nextSession}} • Sessions: {{sessionsCount}}
    </p>
    <p><a class="btn" href="/courses/{{id}}">View &amp; Book</a></p>
  </article>
  {{/courses}}

  {{^courses}}
    <p>No courses available yet.</p>
  {{/courses}}
</div>

{{> footer}}