{{> head}}
{{> header}}

<article>
  <h1>{{course.title}}</h1>
  <p class="muted">
    Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>
  <p class="muted">
    {{#course.location}}Location: {{course.location}}{{/course.location}}
    {{#course.price}} {{#course.location}}•{{/course.location}} Price: £{{course.price}}{{/course.price}}
  </p>

  <section>
    <h2>Book the full course</h2>

    {{#user}}
    <form action="/bookings/course" method="post">
      <input type="hidden" name="courseId" value="{{course._id}}">
      <button class="btn primary" type="submit">Book full course</button>
    </form>
    {{/user}}

    {{^user}}
    <p class="muted">
      <a href="/auth/login">Log in</a> to book this course.
    </p>
    {{/user}}
  </section>

  <section>
    <h2>Sessions</h2>

    {{#sessions}}
    <table class="table">
      <thead>
        <tr>
          <th>Start</th>
          <th>End</th>
          <th>Capacity</th>
          <th>Booked</th>
          <th>Remaining</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>{{start}}</td>
          <td>{{end}}</td>
          <td>{{capacity}}</td>
          <td>{{booked}}</td>
          <td>{{remaining}}</td>
          <td>
            {{#allowDropIn}}
              {{#user}}
              <form action="/bookings/session" method="post">
                <input type="hidden" name="sessionId" value="{{sessionId}}">
                <button class="btn" type="submit" {{#isFull}}disabled{{/isFull}}>
                  Book this session
                </button>
              </form>
              {{/user}}

              {{^user}}
              <span class="muted"><a href="/auth/login">Log in</a> to book</span>
              {{/user}}
            {{/allowDropIn}}

            {{^allowDropIn}}
            <span class="muted">Drop-ins disabled</span>
            {{/allowDropIn}}

            {{#isFull}}
            <span class="muted">Full</span>
            {{/isFull}}
          </td>
        </tr>
      </tbody>
    </table>
    {{/sessions}}

    {{^sessions}}
    <p>No sessions scheduled for this course.</p>
    {{/sessions}}
  </section>
</article>

{{> footer}}